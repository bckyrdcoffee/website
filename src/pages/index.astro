---
import CoinScene from '../components/CoinScene';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>BCKYRD Coffee - From The Land of Indonesia</title>
    <meta
      name="description"
      content="BCKYRD Coffee (Backyard Coffee) - Premium coffee shop in West Jurang Manggu, South Tangerang. Order via GoFood or visit us for the best Indonesian coffee experience."
    />
    <meta
      name="keywords"
      content="bckyrd coffee, backyard coffee, coffee shop tangerang, kopi tangerang selatan, indonesian coffee, specialty coffee, gofood coffee, west jurang manggu coffee"
    />
    <meta name="author" content="BCKYRD Coffee" />
    <link rel="canonical" href="https://bckyrdcoffee.id" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://bckyrdcoffee.id" />
    <meta property="og:site_name" content="BCKYRD Coffee" />
    <meta
      property="og:title"
      content="BCKYRD Coffee - From The Land of Indonesia"
    />
    <meta
      property="og:description"
      content="BCKYRD Coffee (Backyard Coffee) - Premium coffee shop in West Jurang Manggu, South Tangerang. Order via GoFood or visit us for the best Indonesian coffee experience."
    />
    <meta property="og:locale" content="id_ID" />
    <meta property="og:image" content="https://bckyrdcoffee.id/preview.png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta
      name="twitter:title"
      content="BCKYRD Coffee - From The Land of Indonesia"
    />
    <meta
      name="twitter:description"
      content="BCKYRD Coffee (Backyard Coffee) - Premium coffee shop in West Jurang Manggu, South Tangerang. Order via GoFood or visit us."
    />
    <meta name="twitter:image" content="https://bckyrdcoffee.id/preview.png" />

    <!-- Structured Data for Local Business -->
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "CafeOrCoffeeShop",
        "name": "BCKYRD Coffee",
        "alternateName": "Backyard Coffee",
        "description": "Premium Indonesian coffee shop in South Tangerang",
        "url": "https://bckyrdcoffee.id",
        "telephone": "+6281286997816",
        "priceRange": "$$",
        "servesCuisine": "Coffee",
        "address": {
          "@type": "PostalAddress",
          "streetAddress": "West Jurang Manggu",
          "addressLocality": "South Tangerang City",
          "addressRegion": "Banten",
          "addressCountry": "ID"
        },
        "geo": {
          "@type": "GeoCoordinates",
          "url": "https://maps.app.goo.gl/1ittg6AuV18HnEyx9"
        },
        "sameAs": [
          "https://instagram.com/backyardcoffeeandshop",
          "https://gofood.link/u/N0myR"
        ],
        "openingHoursSpecification": {
          "@type": "OpeningHoursSpecification",
          "dayOfWeek": [
            "Monday",
            "Tuesday",
            "Wednesday",
            "Thursday",
            "Friday",
            "Saturday",
            "Sunday"
          ]
        }
      }
    </script>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&family=Staatliches&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <CoinScene client:only="react" />
  </body>
</html>

<style is:global>
  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  html,
  body {
    width: 100%;
    height: 100%;
    overflow: hidden;
    background: #0a0a0f;
  }
</style>
