---
import CoinScene from '../components/CoinScene';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>BCKYRD - From the Land of Indonesia</title>
    <meta
      name="description"
      content="BCKYRD Coffee - Lockd In. From the Land of Indonesia."
    />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://bckyrdcoffee.id" />
    <meta property="og:title" content="BCKYRD - From the Land of Indonesia" />
    <meta
      property="og:description"
      content="BCKYRD Coffee - Lockd In. From the Land of Indonesia."
    />
    <meta property="og:image" content="https://bckyrdcoffee.id/preview.png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="BCKYRD - From the Land of Indonesia" />
    <meta
      name="twitter:description"
      content="BCKYRD Coffee - Lockd In. From the Land of Indonesia."
    />
    <meta name="twitter:image" content="https://bckyrdcoffee.id/preview.png" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&family=Staatliches&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <CoinScene client:only="react" />
  </body>
</html>

<style is:global>
  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  html,
  body {
    width: 100%;
    height: 100%;
    overflow: hidden;
    background: #0a0a0f;
  }
</style>
